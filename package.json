{
    "name": "@jjlmoya/prompagate",
    "version": "1.1.0",
    "description": "Propagates shared prompts to all @jjlmoya ecosystem packages",
    "author": "jjlmoya",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jjlmoya/prompagate.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "files": [
        "prompts",
        "scripts"
    ],
    "scripts": {
        "postinstall": "node scripts/postinstall.js",
        "postversion": "git push && git push --tags",
        "patch": "npm version patch",
        "minor": "npm version minor",
        "major": "npm version major"
    }
}
